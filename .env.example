# MongoDB connection string
# For local: mongodb://localhost:27017/fundgaze
# For Docker Compose: mongodb://mongodb:27017/fundgaze
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/fundgaze
MONGO_DB_URL=mongodb://localhost:27017/fundgaze

# JWT Secret Key - use a long random string in production
SECRET_KEY=change_this_to_a_strong_random_secret_key

# Node Environment
NODE_ENV=development
